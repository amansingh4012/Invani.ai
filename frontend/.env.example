# ════════════════════════════════
# SUPABASE (same project as backend)
# ════════════════════════════════
# Same URL and key as backend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ════════════════════════════════
# BACKEND API URL
# ════════════════════════════════
# Development: your local backend
# Production: your Railway URL
VITE_API_URL=http://localhost:8000


# ════════════════════════════════
# APP NAME (shown in UI)
# ════════════════════════════════
VITE_APP_NAME=VaaniAI
