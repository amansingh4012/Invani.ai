# ── Indian Voice Agent — Environment Variables ──
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Mode ──
MOCK_MODE=true
DEBUG=true

# ── Server ──
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic (Claude AI) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Sarvam AI (Hindi STT + TTS) ──
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text-translate
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech

# ── Exotel (Indian Telephony) ──
EXOTEL_SID=your-exotel-sid
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_SUBDOMAIN=your-subdomain
EXOTEL_CALLER_ID=your-exotel-number
EXOTEL_WEBHOOK_SECRET=your-webhook-secret

# ── WhatsApp (Meta Cloud API) ──
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ── Voice Pipeline ──
SARVAM_STT_LANGUAGE=hi-IN
SARVAM_TTS_SPEAKER=meera
SARVAM_TTS_SPEED=1.0
SARVAM_TTS_PITCH=0.0
AUDIO_SAMPLE_RATE=8000
AUDIO_CHANNELS=1
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=300

# ── Business Defaults ──
DEFAULT_LANGUAGE=hi-IN
DEFAULT_BUSINESS_TYPE=clinic
MAX_CALL_DURATION_SEC=300
ESCALATION_PHONE=+919999999999
